{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["vitest/globals", "vitest/importMeta", "vite/client", "node", "vitest"],
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "bin/**/*.spec.ts",
    "src/**/*.d.ts"
  ]
}
